// World Foundry Production Pathway
// Converted from docs/Production Pathway.dia (v0.4)
// Note: makefiles not shown; not all paths shown.

digraph production_pathway {
    rankdir=TD
    node [fontname="Helvetica" fontsize=10 margin="0.15,0.1"]
    edge [fontsize=9]

    // ── source art / schema files ────────────────────────────────────────────
    oas          [label="*.oas"                                    shape=box]
    objects_mac  [label="objects.mac"                              shape=box]
    oad_iff_txt  [label="Object Attribute Descriptors\noad/*.iff.txt" shape=box]
    oas_ht       [label="Object header files\noas/*.ht"            shape=box]
    source_cc    [label="Source files\n*.cc"                       shape=box]
    textures     [label="textures\n*.tga"                          shape=box]
    ram_iff_txt  [label="ram.iff.txt"                              shape=box]
    matte_tga    [label="matte.map\nmatte.tga"                     shape=box]
    levels_txt   [label="levels.txt"                               shape=box]
    ini_prp      [label="ini.prp"                                  shape=box]
    geometry_ali [label="{geometry}.ali\n(*not currently automated)" shape=box style=dashed]

    // ── intermediate files ───────────────────────────────────────────────────
    objects_lc        [label="List of object types\noas/objects.lc"          shape=box]
    oad_iff           [label="Binary Object Attribute Descriptors\noad/*.iff" shape=box]
    levelname_lev     [label="{levelname}.lev"                               shape=box]
    levelname_lev_bin [label="{levelname}.lev.bin"                           shape=box]
    levelname_lvl     [label="{levelname}.lvl"                               shape=box]
    levelname_ini     [label="{levelname}.ini"                               shape=box]
    objects_id        [label="objects.id"                                    shape=box]
    asset_inc         [label="asset.inc"                                     shape=box]
    geometry_iff_txt  [label="{geometry}.iff.txt"                            shape=box]
    geometry_iff      [label="{geometry}.iff"                                shape=box]
    anim_iff_txt      [label="{single animation cycle}.iff.txt"              shape=box]
    geometry_anim_iff [label="{geometry with animation}.iff"                 shape=box]
    perm_ruv          [label="perm.ruv\nroom*.ruv"                           shape=box]
    perm_tga          [label="perm.tga\nroom*.tga"                           shape=box]
    palperm_tga       [label="palperm.tga\npal*.tga"                         shape=box]
    levelnames_iff    [label="*{levelnames}.iff"                             shape=box]
    cd_iff_txt        [label="cd.iff.txt"                                    shape=box]

    // ── output files ────────────────────────────────────────────────────────
    cd_iff   [label="Entire game data file\ncd.iff" shape=box style=filled fillcolor="#d0e8ff"]
    game_exe [label="game executable"               shape=box style=filled fillcolor="#d0e8ff"]

    // ── tools (predefined process = double-border box) ───────────────────────
    node [shape=box style="filled" fillcolor="#e8f4e8"]

    Prep         [label="Prep"]
    iffcomp_oad  [label="iffcomp"]
    editor_lev   [label="3D editor with\nattribute editor\n& lev exporter"]
    iff2lvl      [label="iff2lvl"]
    iffcomp_lev  [label="iffcomp"]
    prep         [label="prep"]
    textile      [label="textile"]
    iffcomp_lvl  [label="iffcomp"]
    editor_model [label="3D editor\n(modelling/animation)"]
    iffcomp_geo  [label="iffcomp"]
    iffcomp_anim [label="iffcomp"]
    cpp_compiler [label="C++ compiler"]
    cd_pl        [label="cd.pl"]
    iffcomp_cd   [label="iffcomp"]
    execute_game [label="execute game"]

    // ── edges ────────────────────────────────────────────────────────────────
    oas          -> Prep
    objects_mac  -> Prep
    Prep         -> objects_lc
    Prep         -> oad_iff_txt
    Prep         -> oas_ht

    oad_iff_txt  -> iffcomp_oad
    iffcomp_oad  -> oad_iff

    objects_lc   -> editor_lev
    oad_iff      -> editor_lev
    editor_lev   -> levelname_lev

    levelname_lev     -> iffcomp_lev
    iffcomp_lev       -> levelname_lev_bin
    levelname_lev_bin -> iff2lvl
    iff2lvl           -> objects_id
    iff2lvl           -> asset_inc
    iff2lvl           -> levelname_lvl

    asset_inc    -> prep
    ini_prp      -> prep
    prep         -> levelname_ini

    levelname_ini -> textile
    textures      -> textile
    textile       -> perm_ruv
    textile       -> perm_tga
    textile       -> palperm_tga

    perm_ruv          -> iffcomp_lvl
    perm_tga          -> iffcomp_lvl
    palperm_tga       -> iffcomp_lvl
    levelname_lvl     -> iffcomp_lvl
    matte_tga         -> iffcomp_lvl
    geometry_iff      -> iffcomp_lvl
    ram_iff_txt       -> iffcomp_lvl
    geometry_anim_iff -> iffcomp_lvl
    iffcomp_lvl       -> levelnames_iff

    textures         -> editor_model
    editor_model     -> geometry_iff_txt
    editor_model     -> anim_iff_txt
    geometry_iff_txt -> iffcomp_geo
    iffcomp_geo      -> geometry_iff
    geometry_ali     -> iffcomp_anim
    anim_iff_txt     -> iffcomp_anim
    iffcomp_anim     -> geometry_anim_iff

    oas_ht       -> cpp_compiler
    source_cc    -> cpp_compiler
    cpp_compiler -> game_exe

    levels_txt   -> cd_pl
    cd_pl        -> cd_iff_txt
    cd_iff_txt   -> iffcomp_cd
    levelnames_iff -> iffcomp_cd
    iffcomp_cd   -> cd_iff

    game_exe     -> execute_game
    cd_iff       -> execute_game
}
