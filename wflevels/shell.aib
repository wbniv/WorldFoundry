-- shell.lua — default World Foundry game shell (ported from shell.tcl)
-- Runs once per frame at level-startup time.  Toggles a "phase" mailbox
-- (6000) on odd/even ticks; on the first tick (phase clear) it also
-- writes 0 to INDEXOF_LEVEL_TO_RUN as the default-level bootstrap.

local phase = 6000

if read_mailbox(phase) ~= 0 then
    write_mailbox(phase, 0)
else
    write_mailbox(phase, 1)
    write_mailbox(INDEXOF_LEVEL_TO_RUN, 0)
end
